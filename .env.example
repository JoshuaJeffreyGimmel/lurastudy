# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=lurastudy
POSTGRES_PASSWORD=lurastudy
POSTGRES_DB=lurastudy

# ─── LLM Provider (OpenAI-compatible endpoint) ────────────────────────────────
# For Ollama (local):
LLM_BASE_URL=http://host.docker.internal:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=llama3.2

# For OpenAI:
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# ─── Embedding Model (OpenAI-compatible endpoint) ─────────────────────────────
# For Ollama (local):
EMBEDDING_BASE_URL=http://host.docker.internal:11434/v1
EMBEDDING_API_KEY=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768

# For OpenAI:
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_API_KEY=sk-...
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Secret key for signing JWT tokens — change this to a long random string!
SECRET_KEY=change-me-to-a-long-random-secret-key-in-production
# Token expiry in minutes (default: 10080 = 7 days)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ─── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://backend:8000
